{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Los_Angeles",
  "minimumReleaseAge": "3 days",
  "prCreation": "not-pending",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "minimumReleaseAge": null
  },
  "postUpdateOptions": ["gomodTidy"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Version pins preceded by a `# renovate:` marker comment (forgejo workflows)",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z0-9-]+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?(?: extractVersion=(?<extractVersion>\\S+))?\\n\\s*go install \\S+@v(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "14 days"
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go dependencies"
    },
    {
      "description": "conventional-changelog-conventionalcommits v10 is incompatible with @semantic-release/release-notes-generator@14 (still bundles writer@8) -- empty changelogs result. Tracked upstream: semantic-release/release-notes-generator#992, fix in #996. Remove once release-notes-generator ships a writer@9-compatible release.",
      "matchPackageNames": ["conventional-changelog-conventionalcommits"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}